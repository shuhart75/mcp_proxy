      "command": "/home/reutov/.gigacode/.venv/bin/python",
      "args": [
        "-m",
        "confluence_section_mcp.server"
      ],
      "env": {
        "PYTHONPATH": "/home/reutov/confluence-section-mcp/src",
        "CONFLUENCE_SECTION_MODE": "mcp",
